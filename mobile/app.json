{
  "expo": {
    "name": "SCO Academy",
    "slug": "sco-academy",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "sco-academy",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sco.academy",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "تسجيل الفيديوهات التعليمية",
        "NSMicrophoneUsageDescription": "تسجيل الصوت للدروس",
        "NSPhotoLibraryUsageDescription": "رفع الملفات والصور"
      }
    },
    "android": {
      "package": "com.sco.academy",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "sco-academy-project"
      }
    }
  }
}
